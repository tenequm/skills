{
  "name": "impactful-writing",
  "root": "impactful-writing",
  "targets": {
    "validate": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm validate",
        "cwd": "impactful-writing"
      },
      "cache": true,
      "inputs": [
        "{projectRoot}/SKILL.md",
        "{projectRoot}/references/**/*.md",
        "{projectRoot}/package.json"
      ]
    }
  }
}
